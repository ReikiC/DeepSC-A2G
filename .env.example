# DeepSC data root directory.
# Must end with a trailing slash. Should contain the europarl/ folder:
#   europarl/vocab.json
#   europarl/train_data.pkl
#   europarl/test_data.pkl
#   europarl/en/   (raw text, used by preprocess_text.py)
#
# Copy this file to ".env" and adjust the path for your machine:
#   cp .env.example .env
DATA_DIR=/import/antennas/Datasets/hx301/
